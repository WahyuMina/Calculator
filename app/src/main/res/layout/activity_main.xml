<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp"
    tools:context=".MainActivity">

    <ImageButton
        android:id="@+id/btn_show_history"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="end"
        android:layout_marginEnd="3dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/ripple_history"
        android:contentDescription="history_img"
        android:src="@drawable/history"
        android:padding="12dp"
        app:tint="@color/vibrant_orange"
        android:scaleType="fitCenter"/>

    <ScrollView
        android:id="@+id/layout_history"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#1A1A1A"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/light_grey"
            android:textSize="25sp" />
    </ScrollView>

    <TextView
        android:id="@+id/tv_display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:text="0"
        android:textColor="@color/white"
        android:padding="12dp"
        android:maxLines="3"
        android:ellipsize="none"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="18sp"
        app:autoSizeMaxTextSize="64sp"
        app:autoSizeStepGranularity="2sp" />

    <GridLayout
        android:id="@+id/grid_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:columnCount="4"
        android:rowCount="5">

        <Button
            android:id="@+id/btn_clear"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="C"
            android:textColor="#E91E63"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_persen"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="%"
            android:textColor="@color/vibrant_orange"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_eraser"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            android:contentDescription="eraser_button"
            app:backgroundTint="@null"
            app:icon="@drawable/eraser"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp"
            app:iconTint="@color/vibrant_orange" />

        <Button
            android:id="@+id/btn_bagi"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="÷"
            android:textColor="@color/vibrant_orange"
            android:textSize="28sp" />

        <Button
            android:id="@+id/btn_7"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="7"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_8"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="8"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_9"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="9"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_kali"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="×"
            android:textColor="@color/vibrant_orange"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_4"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="4"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_5"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="5"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_6"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="6"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_minus"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="-"
            android:textColor="@color/vibrant_orange"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_1"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_2"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="2"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_3"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="3"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_plus"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="+"
            android:textColor="@color/vibrant_orange"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_landscape"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            android:contentDescription="mode_landscape_button"
            app:backgroundTint="@null"
            app:icon="@drawable/landscape"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp"
            app:iconTint="@color/vibrant_orange" />

        <Button
            android:id="@+id/btn_0"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_coma"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_background"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text=","
            android:textColor="@color/vibrant_orange"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btn_result"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@drawable/btn_operator"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="="
            android:textColor="@color/white"
            android:textSize="24sp" />
    </GridLayout>

</LinearLayout>