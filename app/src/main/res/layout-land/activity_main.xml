<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.7"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingEnd="70dp">

        <ImageButton
            android:id="@+id/btn_show_history"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start"
            android:background="@drawable/ripple_history"
            android:contentDescription="btn_show_history"
            android:src="@drawable/history"
            app:tint="#FF8C00"
            android:padding="12dp"
            android:scaleType="fitCenter"/>

        <TextView
            android:id="@+id/tv_display"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:gravity="bottom|end"
            android:text="0"
            android:textColor="#FF8C00"
            android:textSize="46sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:visibility="visible" />

        <ScrollView
            android:id="@+id/layout_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="#B0B0B0"
                android:textSize="18sp" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="horizontal"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:gravity="center">

        <GridLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:columnCount="3"
            android:rowCount="5">

            <Button
                android:id="@+id/btn_inv" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="INV" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_rad" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="RAD" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_factorial" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="x!" android:textSize="12sp" />

            <Button
                android:id="@+id/btn_sin" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="sin" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_cos" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="cos" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_tan" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="tan" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_in" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="in" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_log" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="log" android:textSize="12sp" />
            <Button android:id="@+id/btn_xy" style="@style/SciBtn" android:layout_columnWeight="1" android:layout_rowWeight="1" android:text="xy^" android:textSize="12sp" />

            <Button
                android:id="@+id/btn_pi" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="π" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_e" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="e" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_sqrt" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="√" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_potrait"
                style="@style/OpBtn" android:layout_columnWeight="1"
                android:layout_rowWeight="1" android:contentDescription="Mode_potrait_button"
                app:icon="@drawable/landscape"
                app:iconSize="24dp"
                app:iconTint="#FF8C00"
                android:paddingLeft="40dp"/>
            <Button
                android:id="@+id/btn_bracket" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="()" android:textSize="12sp" />
            <Button
                android:id="@+id/btn_rank" style="@style/SciBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="x²" android:textSize="12sp" />
        </GridLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#252525" android:layout_margin="10dp" />

        <GridLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.6"
            android:columnCount="4"
            android:rowCount="5">

            <Button
                android:id="@+id/btn_clear" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="C" />
            <Button
                android:id="@+id/btn_persen" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="%" />
            <Button
                android:id="@+id/btn_eraser" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                app:icon="@drawable/eraser" app:iconTint="#FF8C00" android:paddingLeft="40dp" android:contentDescription="Eraser_button" />
            <Button
                android:id="@+id/btn_bagi" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="÷" />
            <Button
                android:id="@+id/btn_7" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="7"  />
            <Button
                android:id="@+id/btn_8" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="8" />
            <Button
                android:id="@+id/btn_9" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="9" />
            <Button
                android:id="@+id/btn_kali" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="x" />
            <Button
                android:id="@+id/btn_4" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="4" />
            <Button
                android:id="@+id/btn_5" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="5" />
            <Button
                android:id="@+id/btn_6" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="6" />
            <Button
                android:id="@+id/btn_minus" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="-" />

            <Button
                android:id="@+id/btn_1" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="1" />
            <Button
                android:id="@+id/btn_2" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="2" />
            <Button
                android:id="@+id/btn_3" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="3" />
            <Button
                android:id="@+id/btn_plus" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="+" />

            <Button
                android:id="@+id/btn_noll" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="00" />
            <Button
                android:id="@+id/btn_nol" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="0" />
            <Button
                android:id="@+id/btn_coma" style="@style/NumBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="," />
            <Button
                android:id="@+id/btn_result" style="@style/OpBtn"
                android:layout_columnWeight="1" android:layout_rowWeight="1"
                android:text="="  android:background="@drawable/btn_operator1"
                android:backgroundTint="@null" app:backgroundTint="@null" android:textColor="#FFFFFF"
                />
        </GridLayout>
    </LinearLayout>
</LinearLayout>